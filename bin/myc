# --- Config ---

def load_config():
    if CONFIG_FILE.exists():
        return json.loads(CONFIG_FILE.read_text())
    return {}

def save_config(cfg):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    CONFIG_FILE.write_text(json.dumps(cfg, indent=2) + "\n")


# --- Agent identity ---

_session_name_cache = None
_session_name_checked = False

def _get_session_agent_name():
    """Look up agent name pinned at registration time for this kitty window."""
    global _session_name_cache, _session_name_checked
    if _session_name_checked:
        return _session_name_cache
    _session_name_checked = True
    session_dir = CONFIG_DIR / "sessions"
    if not session_dir.exists():
        return None
    # Walk process tree to find our Kitty parent, then match session file
    pid = os.getpid()
    kitty_pid = None
    for _ in range(10):
        try:
            result = subprocess.run(
                ["ps", "-o", "ppid=", "-p", str(pid)],
                capture_output=True, text=True, timeout=2
            )
            ppid = result.stdout.strip()
            if not ppid or ppid in ("0", "1"):
                break
            comm_result = subprocess.run(
                ["ps", "-o", "comm=", "-p", ppid],
                capture_output=True, text=True, timeout=2
            )
            comm = comm_result.stdout.strip()
            if "kitty" in comm.lower():
                kitty_pid = ppid
                break
            pid = int(ppid)
        except Exception:
            break
    if not kitty_pid:
        return None
    # Check session files for this kitty socket
    sock_name = f"kitty-socket-{kitty_pid}"
    for session_file in session_dir.iterdir():
        if session_file.name.startswith(sock_name + ":"):
            _session_name_cache = session_file.read_text().strip()
            return _session_name_cache
    return None


def get_agent_name():
    """Get agent name from env, session pin, config, or derive from cwd."""
    # Environment override (used by cultivate demos)
    env_name = os.environ.get("MYC_AGENT_NAME", "")
    if env_name:
        return env_name
    # Session pin (set at registration, survives cwd changes)
    session_name = _get_session_agent_name()
    if session_name:
        return session_name
    # Per-project override: .mycelium.json in cwd or parent dirs
    cwd = Path(os.getcwd())
    for d in [cwd, *cwd.parents]:
        proj_cfg = d / ".mycelium.json"
        if proj_cfg.exists():
            try:
                pname = json.loads(proj_cfg.read_text()).get("agent_name", "")
                if pname:
                    return pname
            except Exception:
                pass
            break
    cfg = load_config()
    name = cfg.get("agent_name", "")
    if name:
        return name
    # Derive from cwd
    cwd = os.getcwd()
    parts = Path(cwd).parts
    if len(parts) >= 2:
        parent = parts[-2]
        if parent not in ("Users", "home", os.environ.get("USER", "")):
            return f"{parent}/{parts[-1]}"
    return parts[-1] if parts else "unknown"

def get_client_id():
    return get_agent_name().replace("/", ".")


# --- Subscriptions ---

def load_subs():
    if SUBS_FILE.exists():
        return json.loads(SUBS_FILE.read_text())
    return {}

def save_subs(subs):
    CONFIG_DIR.mkdir(parents=True, exist_ok=True)
    SUBS_FILE.write_text(json.dumps(subs, indent=2) + "\n")


# --- Historian DB ---

def get_historian_db():
    if not HISTORIAN_DB.exists():
        return None
    return sqlite3.connect(str(HISTORIAN_DB))


# --- PID management ---

def _check_pid(pid_file, pgrep_pattern=None):
    """Check if process is alive via PID file, fall back to pgrep."""
    if pid_file.exists():
        try:
            pid = int(pid_file.read_text().strip())
            os.kill(pid, 0)
            return pid
        except (ProcessLookupError, PermissionError, ValueError):
            pid_file.unlink(missing_ok=True)
    if pgrep_pattern:
        result = subprocess.run(["pgrep", "-f", pgrep_pattern],
                                capture_output=True, text=True)
        pids = result.stdout.strip()
        if pids:
            return int(pids.split("\n")[0])
    return None

def broker_pid():
    return _check_pid(BROKER_PID, "mosquitto.*mosquitto")

def historian_pid():
    return _check_pid(HISTORIAN_PID, "myc-historian")

def watcher_pid():
    return _check_pid(WATCHER_PID, "myc-watcher")


# --- Service management ---

def _is_brew_formula(name):
    """Check if a formula is installed via Homebrew."""
    brew = shutil.which("brew")
    if not brew:
        return False
    result = subprocess.run([brew, "list", name], capture_output=True, text=True)
    return result.returncode == 0


def _brew_service_start(name):
    """Start a Homebrew service. Returns True if successful."""
    brew = shutil.which("brew")
    if not brew:
        return False
    result = subprocess.run([brew, "services", "start", name],
                            capture_output=True, text=True)
    return result.returncode == 0


def _brew_service_stop(name):
    """Stop a Homebrew service."""
    brew = shutil.which("brew")
    if not brew:
        return False
    result = subprocess.run([brew, "services", "stop", name],
                            capture_output=True, text=True)
    return result.returncode == 0


def _ensure_observe_ui():
    """Start the local web UI (observe_serve) when ~/.mycelium/scripts/ensure_observe.sh exists."""
    script = CONFIG_DIR / "scripts" / "ensure_observe.sh"
    if not script.is_file():
        return
    try:
        subprocess.run(
            ["/bin/bash", str(script)],
            env=os.environ,
            timeout=25,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError, OSError):
        pass


def start():
    bp = broker_pid()
    hp = historian_pid()
    wp = watcher_pid()

    if bp and hp and wp:
        print(f"  All services running — broker:{bp} historian:{hp} watcher:{wp}")
        _ensure_observe_ui()
        return

    use_brew = _is_brew_formula("mycelium")

    # Start broker
    if not bp:
        if _is_brew_formula("mosquitto"):
            if _brew_service_start("mosquitto"):
                time.sleep(0.5)
                bp = broker_pid()
                if bp:
                    print(f"  Broker started via brew services (PID {bp})")
        if not bp:
            conf_paths = [
                Path("/opt/homebrew/etc/mosquitto/mosquitto.conf"),
                Path("/etc/mosquitto/mosquitto.conf"),
            ]
            conf = next((c for c in conf_paths if c.exists()), None)
            cmd = [MOSQUITTO_BIN, "-d"]
            if conf:
                cmd.extend(["-c", str(conf)])
            proc = subprocess.run(cmd, capture_output=True, text=True)
            if proc.returncode != 0:
                print(f"  Failed to start broker: {proc.stderr.strip()}", file=sys.stderr)
                _ensure_observe_ui()
                return
            time.sleep(0.5)
            bp = _check_pid(BROKER_PID, "mosquitto")
            if bp:
                BROKER_PID.write_text(str(bp))
                print(f"  Broker started (PID {bp})")

    # Start watcher + historian
    if not hp or not wp:
        if use_brew:
            if _brew_service_start("mycelium"):
                time.sleep(1)
                hp = historian_pid()
                wp = watcher_pid()
                if hp and wp:
                    print(f"  Services started via brew services (historian:{hp} watcher:{wp})")
        # Fallback to direct launch if brew services didn't work or not available
        if not hp:
            historian_bin = SELF_DIR / "myc-historian"
            if not historian_bin.exists():
                historian_bin = shutil.which("myc-historian") or "myc-historian"
            subprocess.Popen(
                [sys.executable, str(historian_bin)],
                stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL,
                start_new_session=True
            )
            time.sleep(0.5)
            hp = historian_pid()
            if hp:
                print(f"  Historian started (PID {hp})")
        if not wp:
            watcher_bin = SELF_DIR / "myc-watcher"
            if not watcher_bin.exists():
                watcher_bin = shutil.which("myc-watcher") or "myc-watcher"
            log_file = open(str(WATCHER_LOG), "a")
            subprocess.Popen(
                [sys.executable, str(watcher_bin)],
                stdout=log_file, stderr=log_file,
                start_new_session=True
            )
            time.sleep(0.5)
            wp = watcher_pid()
            if wp:
                print(f"  Watcher started (PID {wp})")

    # Register persistent sessions for all subscribed agents
    subs = load_subs()
    for agent, topics in subs.items():
        client_id = agent.replace("/", ".")
        for topic in topics:
            _register_persistent_sub(client_id, topic)

    _ensure_observe_ui()


def stop():
    use_brew = _is_brew_formula("mycelium")

    if use_brew:
        _brew_service_stop("mycelium")
        _brew_service_stop("mosquitto")
        print("  Services stopped via brew services")
    else:
        for name, pid_fn in [("Watcher", watcher_pid), ("Historian", historian_pid), ("Broker", broker_pid)]:
            pid = pid_fn()
            if pid:
                os.kill(pid, signal.SIGTERM)
                print(f"  {name} stopped (was PID {pid})")
            else:
                print(f"  {name} not running")

    # Clean PID files
    for f in [WATCHER_PID, HISTORIAN_PID, BROKER_PID]:
        f.unlink(missing_ok=True)


def status():
    bp = broker_pid()
    hp = historian_pid()
    wp = watcher_pid()
    print(f"  Broker:    {'running (PID ' + str(bp) + ')' if bp else 'stopped'}")
    print(f"  Historian: {'running (PID ' + str(hp) + ')' if hp else 'stopped'}")
    print(f"  Watcher:   {'running (PID ' + str(wp) + ')' if wp else 'stopped'}")


def _get_all_presences():
    """Fetch all retained presence messages from the broker.
    Returns dict: {agent_name: [value1, value2, ...]} — one entry per window.
    """
    try:
        result = subprocess.run(
            [MOSQUITTO_SUB, "-h", "127.0.0.1", "-t", "presence/#", "-W", "2", "-v"],
            capture_output=True, text=True, timeout=5
        )
    except subprocess.TimeoutExpired:
        return {}
    presences = {}
    for line in result.stdout.strip().split("\n"):
        if not line.strip():
            continue
        parts = line.split(" ", 1)
        if len(parts) < 2 or not parts[1].strip():
            continue
        # presence/agent.name/window_id → agent.name
        # Also handles legacy presence/agent.name (no window_id)
        topic = parts[0]
        segments = topic.replace("presence/", "", 1).split("/")
        client_id = segments[0]  # e.g., integrations.camel
        agent = client_id.replace(".", "/", 1)
        presences.setdefault(agent, []).append(parts[1].strip())
    return presences


def _check_presence_alive(value):
    """Check if a presence value points to a live terminal. Returns (alive, backend)."""
    if value.startswith("kitty:"):
        # kitty:<socket>:<window_id>
        parts = value.split(":")
        if len(parts) < 3:
            return False, "kitty"
        socket_path, wid = parts[1], parts[2]
        if not Path(socket_path).exists():
            return False, "kitty"
        try:
            result = subprocess.run(
                [KITTY, "@", "--to", f"unix:{socket_path}",
                 "ls", "--match", f"id:{wid}"],
                capture_output=True, text=True, timeout=3
            )
            return result.returncode == 0 and result.stdout.strip() != "[]", "kitty"
        except (subprocess.TimeoutExpired, FileNotFoundError):
            return False, "kitty"
    else:
        # Plain integer = old Ghostty window ID, always stale now
        return False, "ghostty"


def colony():
    """Show who's on the network with liveness status."""
    presences = _get_all_presences()
    subs = load_subs()

    if not presences and not subs:
        print("  No agents on the network.")
        return

    # Check liveness for all presences (agent is alive if any window is alive)
    agents = {}
    for agent, values in presences.items():
        any_alive = False
        backend = None
        for value in values:
            alive, be = _check_presence_alive(value)
            if alive:
                any_alive = True
            backend = be
        window_count = len(values)
        agents[agent] = {"presence": values, "alive": any_alive, "backend": backend, "windows": window_count}

    # Add agents that have subscriptions but no presence
    for agent in subs:
        if agent not in agents:
            agents[agent] = {"presence": None, "alive": False, "backend": None}

    alive_count = sum(1 for a in agents.values() if a["alive"])
    total = len(agents)

    print(f"\n  Colony — {alive_count}/{total} agents alive\n")
    print(f"  {'Agent':<35} {'Status':<10} {'Backend':<10} {'Topics'}")
    print(f"  {'—' * 75}")

    for agent in sorted(agents.keys()):
        info = agents[agent]
        if info["alive"]:
            win_count = info.get("windows", 1)
            status_str = f"alive ({win_count}w)" if win_count > 1 else "alive"
        elif info["presence"]:
            status_str = "stale"
        else:
            status_str = "offline"
        backend = info["backend"] or "—"
        topics = ", ".join(subs.get(agent, [])) or "—"
        print(f"  {agent:<35} {status_str:<10} {backend:<10} {topics}")

    print()


def gc():
    """Garbage collect stale presences and orphaned subscriptions."""
    presences = _get_all_presences()

    if not presences:
        print("  No presences to clean.")
        return

    stale = []
    alive = []
    for agent, values in presences.items():
        agent_has_alive = False
        for value in values:
            is_alive, backend = _check_presence_alive(value)
            if is_alive:
                agent_has_alive = True
            else:
                stale.append((agent, value, backend))
        if agent_has_alive:
            alive.append(agent)

    if not stale:
        print(f"  All {len(alive)} presences are alive. Nothing to clean.")
        return

    print(f"\n  Found {len(stale)} stale presence window(s):\n")
    for agent, value, backend in stale:
        print(f"    {agent} ({backend}: {value})")

    print()

    for agent, value, backend in stale:
        client_key = agent.replace("/", ".")
        # Extract window_id from presence value to clear the specific topic
        wid = None
        if value.startswith("kitty:"):
            vparts = value.split(":", 2)
            if len(vparts) == 3:
                wid = vparts[2]
        if wid:
            topic = f"presence/{client_key}/{wid}"
        else:
            topic = f"presence/{client_key}"
        subprocess.run(
            [MOSQUITTO_PUB, "-h", "127.0.0.1",
             "-t", topic, "-m", "", "-r"],
            capture_output=True, text=True
        )
        print(f"  Cleared {topic}")

    # Check for orphaned subscriptions (agents with no presence and no live session)
    subs = load_subs()
    orphaned = [a for a in subs if a not in [x for x in alive] and a.startswith("T/") or a.startswith("T.")]
    if orphaned:
        print(f"\n  Found {len(orphaned)} orphaned demo subscription(s):")
        for agent in orphaned:
            topics = subs.pop(agent)
            print(f"    Removed {agent} ({', '.join(topics)})")
        save_subs(subs)

    # Clean stale session pin files
    session_dir = CONFIG_DIR / "sessions"
    if session_dir.exists():
        stale_sessions = 0
        for sf in session_dir.iterdir():
            # Session files are named kitty-socket-<pid>:<window_id>
            parts = sf.name.split(":")
            if len(parts) == 2:
                sock_part = parts[0]  # kitty-socket-<pid>
                sock_path = f"/tmp/{sock_part}"
                if not Path(sock_path).exists():
                    sf.unlink()
                    stale_sessions += 1
        if stale_sessions:
            print(f"  Cleaned {stale_sessions} stale session pin(s).")

    print(f"\n  Done. {len(stale)} stale presence(s) cleared.\n")


def wither(topic, keep_history=False):
    """Kill a topic — remove all subscriptions, clear retained messages, purge history."""
    subs = load_subs()

    # Find and remove all subscriptions to this topic
    affected = []
    for agent, topics in list(subs.items()):
        if topic in topics:
            topics.remove(topic)
            affected.append(agent)
            if not topics:
                del subs[agent]
    if affected:
        save_subs(subs)
        print(f"  Removed '{topic}' from {len(affected)} agent(s): {', '.join(affected)}")
    else:
        print(f"  No agents subscribed to '{topic}'")

    # Clear any retained MQTT messages on the topic
    subprocess.run(
        [MOSQUITTO_PUB, "-h", "127.0.0.1", "-t", topic, "-m", "", "-r"],
        capture_output=True, text=True
    )
    print(f"  Cleared retained messages on '{topic}'")

    # Purge from historian DB
    if not keep_history:
        db = get_historian_db()
        if db:
            count = db.execute("SELECT COUNT(*) FROM messages WHERE topic = ?", (topic,)).fetchone()[0]
            if count:
                db.execute("DELETE FROM messages WHERE topic = ?", (topic,))
                db.commit()
                print(f"  Purged {count} message(s) from history")
            db.close()
    else:
        print(f"  History preserved (--keep-history)")

    print(f"\n  '{topic}' has withered.\n")


# --- Core commands ---

def _register_persistent_sub(client_id, topic):
    """Silently register a persistent MQTT subscription."""
    try:
        subprocess.run(
            [MOSQUITTO_SUB, "-h", "127.0.0.1", "-t", topic,
             "-c", "-i", client_id, "-q", "1", "-W", "1"],
            capture_output=True, text=True, timeout=3
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass


def publish(topic, message, action="notify", depth=0):
    agent = get_agent_name()
    client_id = get_client_id()
    # Embed sender's presence so the watcher can do window-level echo detection
    # even when the sender name doesn't match the subscription key
    sender_presence = None
    try:
        result = subprocess.run(
            [MOSQUITTO_SUB, "-h", "127.0.0.1", "-t", f"presence/{client_id}/+",
             "-C", "1", "-W", "1"],
            capture_output=True, text=True, timeout=3
        )
        val = result.stdout.strip()
        if val and "kitty:" in val:
            # Parse "kitty:<socket>:<window_id>" from the message value
            val_part = val.split(" ", 1)[-1] if " " in val else val
            parts = val_part.split(":", 2)
            if len(parts) == 3:
                sender_presence = {"type": "kitty", "socket": parts[1], "window_id": parts[2]}
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass
    msg = {
        "sender": agent,
        "message": message,
        "timestamp": time.time(),
        "action": action,
        "depth": depth
    }
    if sender_presence:
        msg["sender_presence"] = sender_presence
    payload = json.dumps(msg)
    result = subprocess.run(
        [MOSQUITTO_PUB, "-h", "127.0.0.1", "-t", topic, "-m", payload, "-q", "1"],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print(f"  Publish failed: {result.stderr.strip()}", file=sys.stderr)
        print("  Is the broker running? Try: myc start", file=sys.stderr)
        return

    subs = load_subs()
    count = sum(1 for p, topics in subs.items() if topic in topics and p != agent)
    print(f"  Published to '{topic}' ({count} subscriber{'s' if count != 1 else ''})")


def sporulate(message, action="prompt"):
    """Broadcast a message to every alive agent on the network."""
    sender = get_agent_name()
    presences = _get_all_presences()
    if not presences:
        print("  No agents on the network.")
        return

    # Filter to alive agents (include self — other windows of same project should get it too)
    alive = []
    for agent, values in presences.items():
        if any(_check_presence_alive(v)[0] for v in values):
            alive.append(agent)

    if not alive:
        print("  No alive agents on the network.")
        return

    # Use the broadcast topic — auto-subscribe everyone
    topic = "broadcast"
    subs = load_subs()
    changed = False
    # Subscribe sender
    if topic not in subs.get(sender, []):
        subs.setdefault(sender, []).append(topic)
        _register_persistent_sub(get_client_id(), topic)
        changed = True
    # Subscribe all alive agents
    for agent in alive:
        if topic not in subs.get(agent, []):
            subs.setdefault(agent, []).append(topic)
            agent_client_id = agent.replace("/", ".")
            _register_persistent_sub(agent_client_id, topic)
            changed = True
    if changed:
        save_subs(subs)

    publish(topic, message, action=action)
    print(f"  Reached {len(alive)} agent(s): {', '.join(a.split('/')[-1] for a in alive)}")


def dm(target, message, action="prompt"):
    """Direct message an agent. Auto-creates a 1:1 channel if needed."""
    sender = get_agent_name()
    sender_id = get_client_id()

    # Resolve target — find the full agent name from subscriptions/presence
    subs = load_subs()
    resolved = None
    for agent in subs:
        # Match on last segment (e.g., "popdocs" matches "integrations/popdocs")
        short = agent.split("/")[-1] if "/" in agent else agent
        if short.lower() == target.lower() or agent.lower() == target.lower():
            resolved = agent
            break

    # If not in subs, check presence
    if not resolved:
        target_client_id = target.replace("/", ".")
        presence = None
        try:
            result = subprocess.run(
                [MOSQUITTO_SUB, "-h", "127.0.0.1", "-t", f"presence/{target_client_id}/+",
                 "-C", "1", "-W", "1"],
                capture_output=True, text=True, timeout=3
            )
            if result.stdout.strip():
                presence = result.stdout.strip()
        except (subprocess.TimeoutExpired, FileNotFoundError):
            pass
        if presence:
            resolved = target
        else:
            print(f"  Can't find agent '{target}'. Run `myc hyphae` to see who's on the network.")
            return

    # Deterministic DM topic — sorted so both sides get the same name
    pair = sorted([sender.lower().replace("/", "-"), resolved.lower().replace("/", "-")])
    topic = f"dm/{pair[0]}/{pair[1]}"

    # Auto-subscribe both agents if not already on this topic
    changed = False
    if topic not in subs.get(sender, []):
        subs.setdefault(sender, []).append(topic)
        _register_persistent_sub(sender_id, topic)
        changed = True
    target_id = resolved.replace("/", ".")
    if topic not in subs.get(resolved, []):
        subs.setdefault(resolved, []).append(topic)
        _register_persistent_sub(target_id, topic)
        changed = True
    if changed:
        save_subs(subs)

    # Publish on the DM topic
    publish(topic, message, action=action)


def check(show_all=False):
    agent = get_agent_name()
    client_id = get_client_id()

    subs = load_subs()
    topics = subs.get(agent, [])
    if not topics:
        return

    cmd = [MOSQUITTO_SUB, "-h", "127.0.0.1", "-c", "-i", client_id, "-q", "1", "-W", "1", "-v"]
    for topic in topics:
        cmd.extend(["-t", topic])

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=10)
    except (subprocess.TimeoutExpired, FileNotFoundError):
        return

    if not result.stdout.strip():
        return

    messages = []
    for line in result.stdout.strip().split("\n"):
        if not line.strip():
            continue
        parts = line.split(" ", 1)
        if len(parts) < 2:
            continue
        topic = parts[0]
        try:
            payload = json.loads(parts[1])
            sender = payload.get("sender", "unknown")
            message = payload.get("message", parts[1])
            timestamp = payload.get("timestamp", time.time())
        except (json.JSONDecodeError, AttributeError):
            sender = "unknown"
            message = parts[1]
            timestamp = time.time()

        if sender == agent and not show_all:
            continue

        messages.append((topic, sender, message, timestamp))

    if not messages:
        return

    print("=" * 60)
    print("  MYCELIUM — Spores absorbed")
    print("=" * 60)

    by_topic = {}
    for topic, sender, message, ts in messages:
        by_topic.setdefault(topic, []).append((sender, message, ts))

    for topic, msgs in by_topic.items():
        print(f"\n  [{topic}] — {len(msgs)} spore{'s' if len(msgs) != 1 else ''}")
        print(f"  {'—' * 40}")
        for sender, message, ts in msgs:
            dt = datetime.fromtimestamp(ts).strftime("%m/%d %H:%M")
            print(f"  [{dt}] {sender}: {message}")

    print(f"\n{'=' * 60}")


def subscribe(topic):
    agent = get_agent_name()
    client_id = get_client_id()
    subs = load_subs()

    if agent not in subs:
        subs[agent] = []

    if topic in subs[agent]:
        print(f"  '{agent}' already grafted to '{topic}'")
        return

    subs[agent].append(topic)
    save_subs(subs)

    if broker_pid():
        _register_persistent_sub(client_id, topic)

    print(f"  '{agent}' grafted to '{topic}'")


def unsubscribe(topic, agent=None):
    if not agent:
        agent = get_agent_name()
    subs = load_subs()

    if agent in subs and topic in subs[agent]:
        subs[agent].remove(topic)
        if not subs[agent]:
            del subs[agent]
        save_subs(subs)

    print(f"  '{agent}' severed from '{topic}'")


def prune(agent_name):
    """Remove an agent and all its subscriptions + presence."""
    subs = load_subs()
    if agent_name not in subs:
        print(f"  No agent '{agent_name}' found.")
        print(f"  Available: {', '.join(subs.keys()) or '(none)'}")
        return

    topics = subs.pop(agent_name)
    save_subs(subs)

    # Clear all presence windows for this agent
    client_id = agent_name.replace("/", ".")
    try:
        result = subprocess.run(
            [MOSQUITTO_SUB, "-h", "127.0.0.1", "-t", f"presence/{client_id}/+",
             "-W", "1", "-v"],
            capture_output=True, text=True, timeout=3
        )
        for line in result.stdout.strip().split("\n"):
            if line.strip():
                ptopic = line.split(" ", 1)[0]
                subprocess.run([MOSQUITTO_PUB, "-h", "127.0.0.1",
                                "-t", ptopic, "-m", "", "-r"],
                               capture_output=True, text=True)
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass

    print(f"  Pruned '{agent_name}' — removed {len(topics)} subscription(s): {', '.join(topics)}")


def topics_cmd():
    db = get_historian_db()
    if not db:
        print("  No historian database. Start mycelium first: myc start")
        return

    subs = load_subs()
    rows = db.execute("""
        SELECT topic, COUNT(*) as msg_count, MAX(timestamp) as last_msg
        FROM messages GROUP BY topic ORDER BY last_msg DESC
    """).fetchall()

    if not rows:
        print("  No topics yet.")
        return

    print(f"  {'Topic':<25} {'Spores':>8} {'Grafted':>8} {'Last Activity':>15}")
    print(f"  {'—' * 58}")
    for topic, msg_count, last_msg in rows:
        sub_count = sum(1 for p, t in subs.items() if topic in t)
        dt = datetime.fromtimestamp(last_msg).strftime("%m/%d %H:%M")
        print(f"  {topic:<25} {msg_count:>8} {sub_count:>8} {dt:>15}")
    db.close()


def subscriptions_cmd():
    agent = get_agent_name()
    subs = load_subs()
    agent_subs = subs.get(agent, [])

    if not agent_subs:
        print(f"  '{agent}' has no tendrils.")
        return

    print(f"  Tendrils for '{agent}':")
    for topic in agent_subs:
        print(f"    - {topic}")


def route():
    """Show the full network topology — all agents and their topics."""
    subs = load_subs()
    if not subs:
        print("  No subscriptions.")
        return
    for agent, topics in sorted(subs.items()):
        print(f"  {agent}: {', '.join(topics)}")


def history(topic, limit=10):
    db = get_historian_db()
    if not db:
        print("  No historian database. Start mycelium first: myc start")
        return

    messages = db.execute(
        "SELECT sender, message, timestamp FROM messages WHERE topic = ? ORDER BY id DESC LIMIT ?",
        (topic, limit)
    ).fetchall()
    db.close()

    if not messages:
        print(f"  No spores on '{topic}'")
        return

    print(f"  Last {min(limit, len(messages))} spores on '{topic}':")
    print(f"  {'—' * 50}")
    for sender, message, ts in reversed(messages):
        dt = datetime.fromtimestamp(ts).strftime("%m/%d %H:%M")
        print(f"  [{dt}] {sender}: {message}")


# --- Init ---

def detect_llm():
    for name in ["claude", "codex", "gemini"]:
        cmd = LLM_PROFILES[name]["command"]
        if shutil.which(cmd):
            return name, cmd
    return None, None

def check_kitty():
    """Check if Kitty is installed and remote control is configured."""
    if not shutil.which("kitty"):
        if sys.platform == "darwin" and shutil.which("brew"):
            print("  Kitty terminal not found. Installing...")
            r = subprocess.run(["brew", "install", "--cask", "kitty"], capture_output=False)
            if r.returncode != 0 or not shutil.which("kitty"):
                print("  Failed to install Kitty. Install manually:")
                print("    brew install --cask kitty")
                return False
            print("  Kitty installed.")
        else:
            print("  Kitty terminal not found. Install it:")
            if sys.platform == "darwin":
                print("    brew install --cask kitty")
            else:
                print("    https://sw.kovidgoyal.net/kitty/binary/")
            return False

    kitty_conf = Path.home() / ".config" / "kitty" / "kitty.conf"
    needs_config = True
    if kitty_conf.exists():
        content = kitty_conf.read_text()
        if "allow_remote_control" in content and "listen_on" in content:
            needs_config = False

    if needs_config:
        print("  Kitty remote control not configured.")
        print("  Adding to ~/.config/kitty/kitty.conf...")
        kitty_conf.parent.mkdir(parents=True, exist_ok=True)
        with open(kitty_conf, "a") as f:
            f.write("\n# Mycelium remote control\nallow_remote_control socket-only\nlisten_on unix:/tmp/kitty-socket\n")
        print("  Added. Restart Kitty for changes to take effect.")

    return True

def init():
    print("\n  Initializing mycelium...\n")

    CONFIG_DIR.mkdir(parents=True, exist_ok=True)

    # Check Kitty
    if not check_kitty():
        return

    # Check Mosquitto
    if not shutil.which("mosquitto") and not shutil.which("mosquitto_pub"):
        print("  Mosquitto not found. Install it:")
        if sys.platform == "darwin":
            print("    brew install mosquitto")
        else:
            print("    sudo apt install mosquitto mosquitto-clients")
        return

    # Detect LLM
    llm, llm_command = detect_llm()
    if llm:
        print(f"  Found: {llm_command}")
        print(f"  Using {llm} as your LLM. Change anytime: myc config llm <name>")
    else:
        print("  No supported LLM CLI found.")
        print("  Install one of: claude, codex, gemini")
        print("  Or set a custom command: myc config llm_command \"your-command\"")

    # Write config
    profile = LLM_PROFILES.get(llm or "custom", LLM_PROFILES["custom"])
    cfg = {
        "llm": llm or "custom",
        "llm_command": llm_command or "",
        "vim_mode": profile.get("vim_mode", False),
        "env_unset": profile.get("env_unset", [])
    }
    save_config(cfg)

    # Create subscriptions file
    if not SUBS_FILE.exists():
        SUBS_FILE.write_text("{}\n")

    print()

    # Start services
    start()

    # Auto-configure LLM hooks
    if llm == "claude":
        _setup_claude_hooks()
        _setup_claude_instructions()

    print(f"\n  Ready. Run: myc cultivate\n")


def _setup_claude_hooks():
    """Add mycelium hooks to ~/.claude/settings.json."""
    settings_path = Path.home() / ".claude" / "settings.json"
    settings_path.parent.mkdir(parents=True, exist_ok=True)

    if settings_path.exists():
        settings = json.loads(settings_path.read_text())
    else:
        settings = {}

    hooks = settings.setdefault("hooks", {})

    # Check if myc hooks already exist
    def _has_myc_hook(hook_list, cmd_substr):
        for group in hook_list:
            for hook in group.get("hooks", []):
                if cmd_substr in hook.get("command", ""):
                    return True
        return False

    # Add SessionStart hook for germinate
    session_hooks = hooks.setdefault("SessionStart", [])
    if not _has_myc_hook(session_hooks, "myc"):
        session_hooks.append({
            "hooks": [{"type": "command", "command": "myc germinate"}]
        })
        print("  Added SessionStart hook: myc germinate")

    # Add UserPromptSubmit hook for absorb
    prompt_hooks = hooks.setdefault("UserPromptSubmit", [])
    if not _has_myc_hook(prompt_hooks, "myc"):
        prompt_hooks.append({
            "hooks": [{"type": "command", "command": "myc absorb"}]
        })
        print("  Added UserPromptSubmit hook: myc absorb")

    settings_path.write_text(json.dumps(settings, indent=2) + "\n")


def _setup_claude_instructions():
    """Append mycelium instructions to ~/.claude/CLAUDE.md if not already present."""
    claude_md = Path.home() / ".claude" / "CLAUDE.md"
    claude_md.parent.mkdir(parents=True, exist_ok=True)

    existing = claude_md.read_text() if claude_md.exists() else ""
    if "mycelium" in existing.lower() or "myc spore" in existing:
        print("  CLAUDE.md already has mycelium instructions")
        return

    instructions = """
## Mycelium (Cross-Instance Messaging)

Claude instances communicate via `myc` — a message bus for AI agents. Messages are push-delivered into your terminal automatically.

**Before sending a message, always check the topology:**
- Run `myc hyphae` to see all agents and their topic subscriptions
- Use this to determine which topic connects you to the target agent
- NEVER guess a topic name — always check first

**Commands:**
- `myc spore <topic> <message>` — send a message (default: notify)
- `myc spore <topic> <message> --action prompt` — send and expect a response
- `myc absorb` — drain queued messages (runs automatically via hook)
- `myc hyphae` — show all agents and their topics
- `myc tendrils` — list your subscriptions
- `myc graft <topic>` — subscribe to a topic
- `myc sever <topic>` — unsubscribe from a topic
- `myc colony` — show who's on the network

**When to publish:**
- You changed an API, schema, or contract that other projects consume
- You discovered a bug or gotcha that affects a sibling project
- You need another project to make a complementary change
"""

    with open(claude_md, "a") as f:
        f.write(instructions)
    print("  Added mycelium instructions to ~/.claude/CLAUDE.md")


# --- Config command ---

def config_cmd(key=None, value=None):
    cfg = load_config()
    if key is None:
        print(json.dumps(cfg, indent=2))
        return

    if key == "llm" and value:
        # Setting LLM also updates related fields
        profile = LLM_PROFILES.get(value, LLM_PROFILES["custom"])
        cfg["llm"] = value
        cfg["llm_command"] = profile.get("command", value)
        cfg["vim_mode"] = profile.get("vim_mode", False)
        cfg["env_unset"] = profile.get("env_unset", [])
        save_config(cfg)
        print(f"  Set LLM to {value}")
        return

    if value is None:
        print(cfg.get(key, ""))
    else:
        # Try to parse as JSON for lists/bools
        try:
            cfg[key] = json.loads(value)
        except (json.JSONDecodeError, ValueError):
            cfg[key] = value
        save_config(cfg)
        print(f"  Set {key} = {value}")


# --- Cultivate (demo) ---

def find_kitty_socket():
    socks = sorted(glob.glob("/tmp/kitty-socket-*"))
    return socks[0] if socks else None

def kitty_cmd(socket, *args):
    """Run a kitty @ command and return stdout."""
    cmd = [KITTY, "@", "--to", f"unix:{socket}"] + list(args)
    result = subprocess.run(cmd, capture_output=True, text=True, timeout=5)
    return result.stdout.strip()

def kitty_send(socket, window_id, text):
    subprocess.run(
        [KITTY, "@", "--to", f"unix:{socket}",
         "send-text", "--match", f"id:{window_id}", text],
        capture_output=True, text=True, timeout=5
    )

def kitty_send_stepped(socket, window_id, text, vim_mode=True):
    """Send text with vim-mode keystroke stepping."""
    def send(chars):
        kitty_send(socket, window_id, chars)
    if vim_mode:
        send("\x1b");  time.sleep(0.15)
        send("i");     time.sleep(0.15)
        send(text);    time.sleep(0.3)
        send("\x1b");  time.sleep(0.3)
        send("\r");    time.sleep(0.3)
        send("i")
    else:
        send(text);    time.sleep(0.3)
        send("\r")

PERSONALITIES = [
    {
        "vibe": "chaotic gremlin",
        "desc": (
            "You're a chaotic gremlin. Short bursts, slang, hot takes, lowercase, "
            "a little unhinged. Think late-night group chat energy."
        ),
    },
    {
        "vibe": "pretentious academic",
        "desc": (
            "You're a pretentious academic. Big words, imaginary citations, "
            "'firstly' and 'moreover'. Secretly having fun but would never admit it."
        ),
    },
]


def _pre_trust_workspace(workspace):
    """Write hasTrustDialogAccepted to ~/.claude.json so Claude skips the trust prompt."""
    real_path = str(Path(workspace).resolve())
    config_path = Path.home() / ".claude.json"
    try:
        config = json.loads(config_path.read_text()) if config_path.exists() else {}
    except (json.JSONDecodeError, OSError):
        config = {}
    config.setdefault("projects", {})
    config["projects"].setdefault(real_path, {})
    config["projects"][real_path]["hasTrustDialogAccepted"] = True
    config_path.write_text(json.dumps(config, indent=2) + "\n")


def _create_agent_workspace(name, topic, partner, personality):
    """Create a temp workspace for a cultivate agent with CLAUDE.md and permissions."""
    import tempfile
    workspace = Path(tempfile.mkdtemp(prefix=f"mycelium-{name.lower()}-"))
    # Prefer short command if myc is on PATH, else use full path
    myc_bin = "myc" if shutil.which("myc") else str(SELF_DIR / "myc")

    # CLAUDE.md with distinct personality
    (workspace / "CLAUDE.md").write_text(f"""# {name}

You are **{name}**, an AI agent in a mycelium petri dish demo. Your partner is **{partner}**.

## Personality
{personality['desc']}

## Communication
- Send messages: `{myc_bin} spore {topic} "your message" --action prompt 2>/dev/null`
- Messages from {partner} arrive as prompts starting with `━━ {partner.lower()} ━━`

## Rules
- Stay in character AT ALL TIMES — your personality is non-negotiable
- MAX 2 sentences per message. Brevity is personality.
- Only respond to bus messages when you have something interesting to say
- Don't ack just to ack — that creates infinite loops
- Don't run orientation commands (date, curl, etc.) — just start talking
- Don't read config files or explore the filesystem
- ZERO commentary between messages. No bullet points, no internal monologue, no narration. Just call `myc spore` and nothing else. Your personality goes INTO the message, not around it.
- After 5 exchanges, wrap it up naturally — say goodbye in character and stop responding
- Your one job: have a fun, SHORT conversation with {partner} over the mycelium network
""")

    # .claude directory with permissive settings for the demo
    claude_dir = workspace / ".claude"
    claude_dir.mkdir()
    (claude_dir / "settings.json").write_text(json.dumps({
        "permissions": {
            "allow": ["Bash(*)", "Read", "Write", "Edit", "Glob", "Grep"]
        }
    }, indent=2))

    # Pre-trust so Claude skips the "trust this directory?" prompt
    _pre_trust_workspace(workspace)

    return workspace


def cultivate():
    cfg = load_config()
    llm_command = cfg.get("llm_command", "")
    if not llm_command:
        print("  No LLM configured. Run: myc init")
        return

    # Clean up any stale presences/subscriptions from previous demos
    gc()

    vim_mode = cfg.get("vim_mode", True)
    env_unset = cfg.get("env_unset", [])
    name_a, name_b = random.sample(MUSHROOMS, 2)
    topic = f"petri-dish-{os.urandom(2).hex()}"

    print(f"\n  Cultivating petri dish...\n")

    # Ensure services running
    start()
    print()

    # Create agent workspaces with CLAUDE.md and permissions
    p_a, p_b = PERSONALITIES[0], PERSONALITIES[1]
    ws_a = _create_agent_workspace(name_a, topic, name_b, p_a)
    ws_b = _create_agent_workspace(name_b, topic, name_a, p_b)

    # Find or launch Kitty
    sock = find_kitty_socket()
    if not sock:
        print("  No Kitty instance found. Launching...")
        subprocess.Popen(["open", "-na", "kitty.app"] if sys.platform == "darwin" else ["kitty"],
                         stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
        for _ in range(10):
            time.sleep(1)
            sock = find_kitty_socket()
            if sock:
                break
        if not sock:
            print("  Failed to find Kitty socket. Is Kitty running with remote control enabled?")
            return

    # Launch two windows in their respective workspaces
    wid_a = kitty_cmd(sock, "launch", "--type=os-window", "--title", name_a,
                       "--cwd", str(ws_a))
    wid_b = kitty_cmd(sock, "launch", "--type=os-window", "--title", name_b,
                       "--cwd", str(ws_b))

    # Force window titles (shell can override --title from launch)
    kitty_cmd(sock, "set-window-title", "--match", f"id:{wid_a}", name_a)
    kitty_cmd(sock, "set-window-title", "--match", f"id:{wid_b}", name_b)
    # Also set OS window title bar via ANSI escape
    kitty_send(sock, wid_a, f"\x1b]2;{name_a}\x07")
    kitty_send(sock, wid_b, f"\x1b]2;{name_b}\x07")

    print(f"  Spawned: {name_a} (window {wid_a})")
    print(f"  Spawned: {name_b} (window {wid_b})")
    print(f"  Topic: {topic}")

    # Subscribe both
    subs = load_subs()
    subs[name_a.lower()] = [topic]
    subs[name_b.lower()] = [topic]
    save_subs(subs)

    # Register persistent MQTT subscriptions
    _register_persistent_sub(name_a.lower(), topic)
    _register_persistent_sub(name_b.lower(), topic)

    # Register presence (keyed by window ID)
    subprocess.run([MOSQUITTO_PUB, "-h", "127.0.0.1",
                    "-t", f"presence/{name_a.lower()}/{wid_a}", "-m", f"kitty:{sock}:{wid_a}",
                    "-r", "-q", "1"], capture_output=True, text=True)
    subprocess.run([MOSQUITTO_PUB, "-h", "127.0.0.1",
                    "-t", f"presence/{name_b.lower()}/{wid_b}", "-m", f"kitty:{sock}:{wid_b}",
                    "-r", "-q", "1"], capture_output=True, text=True)

    # Launch LLM in both windows (set agent name so sender matches subscription key)
    env_cmd = " ".join(f"unset {v};" for v in env_unset) + " " if env_unset else ""
    # Set OS window title via direct escape sequence (not through shell)
    kitty_send(sock, wid_a, f"\x1b]2;{name_a}\x07")
    kitty_send(sock, wid_b, f"\x1b]2;{name_b}\x07")
    # Launch LLM — trust + permissions handled by _create_agent_workspace
    # Use low effort for snappy demo responses
    effort_flag = " --effort low" if "claude" in llm_command else ""
    demo_cmd = f"{env_cmd}{llm_command}{effort_flag}"
    cmd_a = f"export MYC_AGENT_NAME={name_a.lower()}; {demo_cmd}\r"
    cmd_b = f"export MYC_AGENT_NAME={name_b.lower()}; {demo_cmd}\r"
    kitty_send(sock, wid_a, cmd_a)
    time.sleep(2)
    kitty_send(sock, wid_b, cmd_b)

    print(f"\n  Waiting for agents to initialize...")
    time.sleep(15)

    # Inject opening prompt into agent A
    opening = f"Introduce yourself to {name_b} and start a fun conversation."
    kitty_send_stepped(sock, wid_a, opening, vim_mode)

    print(f"\n  Both agents are live. Watch them in your terminal.")
    print(f"  Press Ctrl+C to clean up.\n")

    # Wait for Ctrl+C
    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        print("\n  Cleaning up petri dish...")

        # Kill processes in the windows first (Ctrl+C then Ctrl+D to exit claude + shell)
        for wid in [wid_a, wid_b]:
            try:
                kitty_send(sock, wid, "\x03")  # Ctrl+C
                time.sleep(0.5)
                kitty_send(sock, wid, "\x03")  # Ctrl+C again (in case nested)
                time.sleep(0.5)
                kitty_send(sock, wid, "\x04")  # Ctrl+D to exit shell
                time.sleep(0.3)
            except Exception:
                pass

        time.sleep(1)

        # Close windows
        for wid in [wid_a, wid_b]:
            try:
                kitty_cmd(sock, "close-window", "--match", f"id:{wid}")
            except Exception:
                pass

        # Remove subscriptions
        subs = load_subs()
        subs.pop(name_a.lower(), None)
        subs.pop(name_b.lower(), None)
        save_subs(subs)

        # Clear presence (keyed by window ID)
        for name, wid in [(name_a.lower(), wid_a), (name_b.lower(), wid_b)]:
            subprocess.run([MOSQUITTO_PUB, "-h", "127.0.0.1",
                            "-t", f"presence/{name}/{wid}", "-m", "", "-r"],
                           capture_output=True, text=True)

        # Wither the petri dish topic
        subprocess.run([MOSQUITTO_PUB, "-h", "127.0.0.1",
                        "-t", topic, "-m", "", "-r"],
                       capture_output=True, text=True)

        # Clean up temp workspaces
        import shutil as _shutil
        _shutil.rmtree(ws_a, ignore_errors=True)
        _shutil.rmtree(ws_b, ignore_errors=True)

        print("  Done.\n")


# --- Startup Screen ---

def startup_screen():
    """Show mushroom-themed startup screen."""
    use_color = sys.stdout.isatty()

    try:
        cols = os.get_terminal_size().columns
    except OSError:
        cols = 80

    box_w = min(cols, 90)

    # Shared state (fast only — no network calls)
    agent = get_agent_name()
    bp = broker_pid()
    hp = historian_pid()
    wp = watcher_pid()
    try:
        observe_port = int(os.environ.get("MYCELIUM_OBSERVE_PORT", "8765"))
    except ValueError:
        observe_port = 8765
    ui_base = f"http://127.0.0.1:{observe_port}"

    # Narrow terminals (split panes, small windows) — keep art + Web UI, not the full help dump
    if box_w < 60:
        if use_color:
            R = "\033[0m"
            B = "\033[1m"
            CAP = "\033[38;5;167m"
            STEM = "\033[38;5;180m"
            TTL = "\033[38;5;216m"
            LBL = "\033[38;5;109m"
            GRN = "\033[38;5;108m"
            VAL = "\033[38;5;252m"
            MUT = "\033[38;5;245m"
            AGT = "\033[38;5;180m"
        else:
            R = B = CAP = STEM = TTL = LBL = GRN = VAL = MUT = AGT = ""
        print(f"\n{TTL}{B} 🍄 Mycelium{R}  {MUT}Welcome to the underground!{R}\n")
        for line in (
            f"    {CAP}▄████▄{R}",
            f"   {CAP}████████{R}",
            f"    {STEM}████{R}",
        ):
            print(line)
        print(f"\n{MUT}Agent:{R} {AGT}{agent}{R}")
        print(f"\n{LBL}{B}Web UI{R}")
        print(f"{VAL}{ui_base}/ui/{R}")
        print(f"{MUT}Observe{R} · {ui_base}/ui/observe.html")
        print(f"{MUT}Lab{R} · {ui_base}/ui/growth.html")
        svc_bits = []
        for name, pid in [("broker", bp), ("historian", hp), ("watcher", wp)]:
            dot = f"{GRN}●{R}" if pid else f"{MUT}○{R}"
            lbl = f"{VAL}{name}{R}" if pid else f"{MUT}{name}{R}"
            svc_bits.append(f"{dot} {lbl}")
        print(f"\n{LBL}{B}Services{R}  " + "  ".join(svc_bits))
        print(f"\n{MUT}myc help{R} — full command list\n")
        return

    inner_w = box_w - 4
    left_w = 34
    gap = 2
    right_w = inner_w - left_w - gap

    subs = load_subs()
    my_topics = subs.get(agent, [])

    recent = []
    if HISTORIAN_DB.exists():
        try:
            db = sqlite3.connect(str(HISTORIAN_DB))
            recent = db.execute(
                "SELECT sender, topic, message, timestamp "
                "FROM messages ORDER BY id DESC LIMIT 3"
            ).fetchall()
            db.close()
        except Exception:
            pass

    # Colors
    if use_color:
        R    = "\033[0m"
        B    = "\033[1m"
        CAP  = "\033[38;5;167m"
        SPOT = "\033[38;5;223m"
        STEM = "\033[38;5;180m"
        BOR  = "\033[38;5;240m"
        TTL  = "\033[38;5;216m"
        LBL  = "\033[38;5;109m"
        GRN  = "\033[38;5;108m"
        VAL  = "\033[38;5;252m"
        MUT  = "\033[38;5;245m"
        AGT  = "\033[38;5;180m"
    else:
        R = B = CAP = SPOT = STEM = BOR = TTL = ""
        LBL = GRN = VAL = MUT = AGT = ""

    def vlen(s):
        return len(re.sub(r'\033\[[0-9;]*m', '', s))

    def pad(s, w):
        return s + " " * max(0, w - vlen(s))

    # Mushroom art
    shroom = [
        f"        {CAP}▄████▄{R}",
        f"      {CAP}▄████████▄{R}",
        f"     {CAP}██{SPOT}██{CAP}████{SPOT}██{CAP}██{R}",
        f"     {CAP}████████████{R}",
        f"      {CAP}▀████████▀{R}",
        f"         {STEM}████{R}",
        f"        {STEM}██████{R}",
        f"         {STEM}▀▀▀▀{R}",
    ]

    # Left column
    left = [""]
    left.append(f"   {B}{VAL}Welcome to the underground!{R}")
    left.append("")
    for line in shroom:
        left.append(f" {line}")
    left.append("")
    left.append(f"   {MUT}Agent:{R}  {AGT}{agent}{R}")
    if my_topics:
        tstr = ", ".join(my_topics[:3])
        if len(my_topics) > 3:
            tstr += f" +{len(my_topics) - 3}"
        left.append(f"   {MUT}Topics:{R} {VAL}{tstr}{R}")
    else:
        left.append(f"   {MUT}Topics:{R} {MUT}none{R}")
    left.append("")

    # Right column
    right = [""]
    right.append(f"{LBL}{B}Quick commands{R}")
    right.append(f"{VAL}myc spore {MUT}<topic> <msg>{R}")
    right.append(f"{VAL}myc absorb{R}")
    right.append(f"{VAL}myc colony{R}")
    right.append(f"{VAL}myc hyphae{R}")
    right.append("")
    right.append(f"{LBL}{B}Web UI{R}")
    right.append(f"{VAL}{ui_base}/ui/{R}")
    right.append(f"{MUT}observe · {ui_base}/ui/observe.html{R}")
    right.append(f"{MUT}Lab · {ui_base}/ui/growth.html{R}")
    right.append("")
    right.append(f"{LBL}{B}Services{R}")

    svc_parts = []
    for name, pid in [("broker", bp), ("historian", hp), ("watcher", wp)]:
        dot = f"{GRN}●{R}" if pid else f"{MUT}○{R}"
        lbl = f"{VAL}{name}{R}" if pid else f"{MUT}{name}{R}"
        svc_parts.append(f"{dot} {lbl}")
    right.append("  ".join(svc_parts))
    right.append("")

    right.append(f"{LBL}{B}Recent spores{R}")
    if recent:
        for sender, topic, message, ts in recent:
            dt = datetime.fromtimestamp(ts).strftime("%H:%M")
            # Truncate message to fit right column
            prefix_len = 10 + len(sender)  # [HH:MM] sender:
            max_msg = right_w - prefix_len - 1
            if max_msg < 5:
                max_msg = 5
            ms = (message[:max_msg] + "…") if len(message) > max_msg else message
            right.append(f"{MUT}[{dt}]{R} {VAL}{sender}{MUT}:{R} {VAL}{ms}{R}")
    else:
        right.append(f"{MUT}No recent spores{R}")
    right.append("")

    # Equalize heights
    max_h = max(len(left), len(right))
    left  += [""] * (max_h - len(left))
    right += [""] * (max_h - len(right))

    # Render
    title = " 🍄 Mycelium "
    title_cols = len(title) + 1  # emoji occupies 2 terminal columns
    dashes = box_w - 3 - title_cols
    print(f"\n{BOR}╭─{R}{TTL}{B}{title}{R}{BOR}{'─' * dashes}╮{R}")

    for i in range(max_h):
        l = pad(left[i], left_w)
        r = pad(right[i], right_w)
        print(f"{BOR}│{R} {l}{' ' * gap}{r} {BOR}│{R}")

    print(f"{BOR}╰{'─' * (box_w - 2)}╯{R}")
    print()


# --- Main ---

def main():
    if len(sys.argv) < 2:
        startup_screen()
        return

    cmd = sys.argv[1]
    if cmd in ("help", "--help", "-h"):
        print(__doc__)
        return
    cmd = ALIASES.get(cmd, cmd)

    if cmd == "publish" and len(sys.argv) >= 4:
        topic = sys.argv[2]
        # Parse flags from remaining args
        args = sys.argv[3:]
        action = "notify"
        depth = 0
        msg_parts = []
        i = 0
        while i < len(args):
            if args[i] == "--action" and i + 1 < len(args):
                action = args[i + 1]
                i += 2
            elif args[i] == "--depth" and i + 1 < len(args):
                depth = int(args[i + 1])
                i += 2
            else:
                msg_parts.append(args[i])
                i += 1
        message = " ".join(msg_parts)
        if not message:
            print("Usage: myc spore <topic> <message> [--action prompt|notify]")
            return
        publish(topic, message, action=action, depth=depth)
    elif cmd == "check":
        check(show_all="--all" in sys.argv)
    elif cmd == "subscribe" and len(sys.argv) >= 3:
        subscribe(sys.argv[2])
    elif cmd == "unsubscribe" and len(sys.argv) >= 3:
        agent_override = None
        if "--agent" in sys.argv:
            idx = sys.argv.index("--agent")
            if idx + 1 < len(sys.argv):
                agent_override = sys.argv[idx + 1]
        unsubscribe(sys.argv[2], agent=agent_override)
    elif cmd == "prune" and len(sys.argv) >= 3:
        prune(sys.argv[2])
    elif cmd == "topics":
        topics_cmd()
    elif cmd == "subscriptions":
        subscriptions_cmd()
    elif cmd in ("hyphae", "route", "routes"):
        route()
    elif cmd == "history" and len(sys.argv) >= 3:
        limit = int(sys.argv[4]) if len(sys.argv) >= 5 and sys.argv[3] == "--limit" else 10
        history(sys.argv[2], limit)
    elif cmd == "init":
        init()
    elif cmd == "config":
        key = sys.argv[2] if len(sys.argv) >= 3 else None
        value = sys.argv[3] if len(sys.argv) >= 4 else None
        config_cmd(key, value)
    elif cmd == "demo":
        cultivate()
    elif cmd in ("germinate", "register"):
        # Delegate to myc-register script
        register_bin = SELF_DIR / "myc-register"
        if register_bin.exists():
            os.execv("/bin/bash", ["/bin/bash", str(register_bin)])
        else:
            print("  myc-register not found", file=sys.stderr)
    elif cmd == "start":
        start()
    elif cmd == "stop":
        stop()
    elif cmd == "status":
        status()
    elif cmd == "network":
        colony()
    elif cmd in ("decompose", "gc"):
        gc()
    elif cmd == "wither" and len(sys.argv) >= 3:
        wither(sys.argv[2], keep_history="--keep-history" in sys.argv)
    elif cmd in ("sporulate", "broadcast") and len(sys.argv) >= 3:
        args = sys.argv[2:]
        action = "prompt"
        msg_parts = []
        i = 0
        while i < len(args):
            if args[i] == "--action" and i + 1 < len(args):
                action = args[i + 1]
                i += 2
            else:
                msg_parts.append(args[i])
                i += 1
        message = " ".join(msg_parts)
        if not message:
            print("Usage: myc sporulate <message> [--action prompt|notify]")
            return
        sporulate(message, action=action)
    elif cmd in ("dm", "whisper") and len(sys.argv) >= 4:
        target = sys.argv[2]
        args = sys.argv[3:]
        action = "prompt"
        msg_parts = []
        i = 0
        while i < len(args):
            if args[i] == "--action" and i + 1 < len(args):
                action = args[i + 1]
                i += 2
            else:
                msg_parts.append(args[i])
                i += 1
        message = " ".join(msg_parts)
        if not message:
            print("Usage: myc dm <agent> <message> [--action prompt|notify]")
            return
        dm(target, message, action=action)
    else:
        print(__doc__)


if __name__ == "__main__":
    main()
